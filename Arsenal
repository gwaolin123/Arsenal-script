-- WALLHACK
local wallhackObjects = {}
local function createWallhack(player)
    if player == LocalPlayer then return end
    local box = Drawing.new("Box")
    local nameTag = Drawing.new("Text")
    local distanceText = Drawing.new("Text")
    box.Thickness = 2
    box.Transparency = 1
    box.Filled = false
    nameTag.Size = 14
    nameTag.Center = true
    nameTag.Outline = true
    distanceText.Size = 12
    distanceText.Center = true
    distanceText.Color = Color3.new(1, 1, 0)
    box.Visible = false
    nameTag.Visible = false
    distanceText.Visible = false
    wallhackObjects[player] = {box = box, nameTag = nameTag, distance = distanceText}
    RunService.RenderStepped:Connect(function()
        if not wallhackEnabled or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                if box then box.Visible = false end
                if nameTag then nameTag.Visible = false end
                if distanceText then distanceText.Visible = false end
            end)
            return
        end
        pcall(function()
            local isEnemy = true
            if player.Team and LocalPlayer.Team then
                isEnemy = player.Team ~= LocalPlayer.Team
            end
            local boxColor = isEnemy and Color3.new(1, 0, 0) or Color3.new(0, 0.4, 1)
            local nameColor = isEnemy and Color3.new(1, 0.5, 0.5) or Color3.new(0.5, 0.7, 1)
            local rootPart = player.Character.HumanoidRootPart
            local screenPos, _ = Camera:WorldToViewportPoint(rootPart.Position)
            local distance = (Camera.CFrame.Position - rootPart.Position).Magnitude
            local scale = 3 / math.max(distance, 1) * 5
            local height = 5 * scale
            local width = 3 * scale
            box.Color = boxColor
            box.Size = Vector2.new(width * 50, height * 50)
            box.Position = Vector2.new(screenPos.X - width * 25, screenPos.Y - height * 25)
            box.Visible = true
            nameTag.Color = nameColor
            nameTag.Text = player.Name .. " | " .. math.floor((player.Character.Humanoid and player.Character.Humanoid.Health) or 100)
            nameTag.Position = Vector2.new(screenPos.X, screenPos.Y - height * 25 - 12)
            nameTag.Visible = true
            distanceText.Text = math.floor(distance) .. "m"
            distanceText.Position = Vector2.new(screenPos.X, screenPos.Y + height * 25 + 8)
            distanceText.Visible = true
        end)
    end)
end

-- Aimbot
local function getClosestEnemy3D()
    local closest = nil
    local shortestDist = math.huge
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local isEnemy = true
            if player.Team and LocalPlayer.Team then
                isEnemy = player.Team ~= LocalPlayer.Team
            end
            if isEnemy then
                local enemyPos = player.Character.HumanoidRootPart.Position
                local myPos = Camera.CFrame.Position
                local dist = (enemyPos - myPos).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    closest = player
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if not aimbotEnabled then return end
    local target = getClosestEnemy3D()
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local targetPos = target.Character.HumanoidRootPart.Position
        local lookVector = (targetPos - Camera.CFrame.Position).Unit
        local newCFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + lookVector)
        Camera.CFrame = Camera.CFrame:Lerp(newCFrame, 0.6)
        VirtualUser:Button1Down(Vector2.new(0,0))
        wait(0.01)
        VirtualUser:Button1Up(Vector2.new(0,0))
    end
end)

-- Fly
local flying = false
local bodyVelocity = nil
local bodyGyro = nil
local function startFly()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = hrp
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bodyGyro.Parent = hrp
    bodyGyro.CFrame = hrp.CFrame
end

UserInputService.InputBegan:Connect(function(input)
    if not flyEnabled or not flying then return end
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local speed = 100
    if input.KeyCode == Enum.KeyCode.W then bodyVelocity.Velocity = hrp.CFrame.LookVector * speed end
    if input.KeyCode == Enum.KeyCode.S then bodyVelocity.Velocity = hrp.CFrame.LookVector * -speed end
    if input.KeyCode == Enum.KeyCode.A then bodyVelocity.Velocity = hrp.CFrame.RightVector * -speed end
    if input.KeyCode == Enum.KeyCode.D then bodyVelocity.Velocity = hrp.CFrame.RightVector * speed end
    if input.KeyCode == Enum.KeyCode.Space then bodyVelocity.Velocity = Vector3.new(0, speed, 0) end
end)

local function stopFly()
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    bodyVelocity = nil
    bodyGyro = nil
end

-- Speed
local function setSpeed()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = speedValue
    end
end
local function resetSpeed()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = 16
    end
end

